{
  "name": "@midnight-ntwrk/bboard-contract",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build:ui": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "build:contract": "rm -rf dist && tsc --project tsconfig.build.json && cp -Rf ./managed ./dist/managed && cp ./contracts/ghost.compact ./dist",
    "build": "next build --webpack",
    "ci": "npm run compact && npm run typecheck && npm run lint && npm run build && npm run test",
    "compact": "compact compile contracts/ghost.compact ./managed/ghost && cp ./managed/ghost/*.zkir ./public/ && cp ./managed/ghost/*.pk ./public/ || true",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "rollup": "^4.62.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@midnight-ntwrk/compact-runtime": "^0.16.0",
    "@midnight-ntwrk/dapp-connector-api": "^4.0.1",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "^4.1.1",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "^4.1.1",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "^4.1.1",
    "@midnight-ntwrk/midnight-js-network-id": "^4.1.1",
    "@midnight-ntwrk/testkit-js": "^4.1.1",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@radix-ui/react-progress": "^1.1.13",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-slider": "^1.4.4",
    "@radix-ui/react-switch": "^1.3.4",
    "@radix-ui/react-tabs": "^1.1.18",
    "@radix-ui/react-toast": "^1.2.20",
    "@radix-ui/react-tooltip": "^1.2.13",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@supabase/supabase-js": "^2.110.8",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.4",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "fp-ts": "^2.16.11",
    "framer-motion": "^12.42.2",
    "isomorphic-ws": "^5.0.0",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "pino": "^10.3.1",
    "postcss": "^8.5.20",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.82.0",
    "recharts": "^3.9.2",
    "rxjs": "^7.8.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "three": "^0.185.1",
    "ws": "^8.21.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  }
}
